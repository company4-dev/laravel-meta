{
    "name": "company4-dev/laravel-meta",
    "description": "Fluent Meta Data for Eloquent Models, as if it is a property on your model.",
    "keywords": [
        "laravel",
        "meta",
        "metas",
        "meta data",
        "data",
        "metadata",
        "metable",
        "model",
        "eloquent",
        "kodeine",
        "company4"
    ],
    "authors": [
        {
            "name": "Jas-n",
            "homepage": "https://github.com/company4-dev",
            "role": "Owner"
        },
        {
            "name": "Ahsen M.",
            "homepage": "https://github.com/kodeine",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.2",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/events": "^10.0|^11.0|^12.0|^13.0",
        "ext-json": "*"
    },
    "autoload": {
        "classmap": [],
        "psr-0": {
            "Kodeine\\Metable\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kodeine\\Metable\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "license": "MIT",
    "require-dev": {
        "phpunit/phpunit": "^9.5|^10.5"
    }
}
